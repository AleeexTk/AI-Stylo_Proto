{
  "manifest_version": 3,
  "name": "AI-Stylo Universal Assistant",
  "version": "0.1.0",
  "description": "Personal AI Stylist that works on any fashion website (Chrome EPP Early Access).",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "aiLanguageModelOriginTrial"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Open AI-Stylo"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
